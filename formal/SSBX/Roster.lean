def entryOf : Symbol -> Entry
  | s@(Symbol.atom _) =>
      { symbol := s, label := s.label, kind := .atom, sort := .term,
        roots := [s], deps := [], polarity := .none, recSem := none }
  | s@(Symbol.generated g) =>
      { symbol := s, label := s.label, kind := .generated, sort := .term,
        roots := rootsOfGenerated g, deps := depsOfGenerated g,
        polarity := .positive, recSem := none }
  | s@(Symbol.primitive _) =>
      { symbol := s, label := s.label, kind := .primitive, sort := .model,
        roots := [], deps := [], polarity := .none, recSem := none }
  | s@(Symbol.recursive r) =>
      { symbol := s, label := s.label, kind := .recursive, sort := .truth,
        roots := [], deps := recDeps r, polarity := .mixed,
        recSem := some (recSemOf r) }
  | s@(Symbol.pending _) =>
      { symbol := s, label := s.label, kind := .pending, sort := .truth,
        roots := [], deps := [], polarity := .none, recSem := none }

