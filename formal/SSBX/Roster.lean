def allSymbols : List Symbol :=
  (allAtoms.map Symbol.atom) ++
  (allGenerated.map Symbol.generated) ++
  (allPrimitives.map Symbol.primitive) ++
  (allRecursive.map Symbol.recursive) ++
  (allPending.map Symbol.pending)

def allEntries : List Entry := allSymbols.map entryOf

theorem generated_entries_have_roots (g : GenName) :
    (entryOf (G g)).roots ≠ [] := by
  cases g <;> decide

theorem recursive_entries_have_semantics (r : RecName) :
    ∃ sem, (entryOf (R r)).recSem = some sem := by
  cases r <;> simp [entryOf, recSemOf]

theorem pending_entries_are_pending (p : PendingName) :
    (entryOf (U p)).kind = Kind.pending := rfl

theorem all_symbols_have_entries (s : Symbol) :
    ∃ e, e = entryOf s :=
  ⟨entryOf s, rfl⟩

/-- Candidate coverage theorem for the explicit Chinese roster. If Lean reports
a failure here, the corresponding constructor was added but not listed in
`allSymbols`. -/
theorem allSymbols_complete (s : Symbol) : s ∈ allSymbols := by
  cases s with
  | atom a => cases a <;> native_decide
  | generated g => cases g <;> native_decide
  | primitive p => cases p <;> native_decide
  | recursive r => cases r <;> native_decide
  | pending u => cases u <;> native_decide

end SSBX.Roster
